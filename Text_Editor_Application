// ============================================================================
// CUSTOM DATA STRUCTURE
// ============================================================================
struct LineNode {
    string text;
    LineNode* prev;
    LineNode* next;

    LineNode(string txt) : text(txt), prev(nullptr), next(nullptr) {}
};

class TextBuffer {
private:
    LineNode* head;
    LineNode* tail;
    int lineCount;

public:
    TextBuffer() : head(nullptr), tail(nullptr), lineCount(0) {}

    ~TextBuffer() {
        clear();
    }

    void clear() {
        LineNode* current = head;
        while (current != nullptr) {
            LineNode* nextNode = current->next;
            delete current;
            current = nextNode;
        }
        head = tail = nullptr;
        lineCount = 0;
    }

    int getLineCount() const { return lineCount; }
    LineNode* getHead() const { return head; }

    void appendLine(string txt) {
        LineNode* newNode = new LineNode(txt);
        if (!head) {
            head = tail = newNode;
        } else {
            tail->next = newNode;
            newNode->prev = tail;
            tail = newNode;
        }
        lineCount++;
    }

    bool insertNewLineNode(int index, string txt) {
        if (index < 0 || index > lineCount) return false;
        if (index == lineCount) {
            appendLine(txt);
            return true;
        }

        LineNode* newNode = new LineNode(txt);
        if (index == 0) {
            newNode->next = head;
            head->prev = newNode;
            head = newNode;
        } else {
            LineNode* curr = head;
            for (int i = 0; i < index; i++) curr = curr->next;
            
            newNode->prev = curr->prev;
            newNode->next = curr;
            curr->prev->next = newNode;
            curr->prev = newNode;
        }
        lineCount++;
        return true;
    }

    bool deleteLineNode(int index) {
        if (index < 0 || index >= lineCount || !head) return false;

        LineNode* curr = head;
        for (int i = 0; i < index; i++) curr = curr->next;

        if (curr == head && curr == tail) {
            head = tail = nullptr;
        } else if (curr == head) {
            head = head->next;
            head->prev = nullptr;
        } else if (curr == tail) {
            tail = tail->prev;
            tail->next = nullptr;
        } else {
            curr->prev->next = curr->next;
            curr->next->prev = curr->prev;
        }

        delete curr;
        lineCount--;
        return true;
    }

    string* getLineString(int index) {
        if (index < 0 || index >= lineCount) return nullptr;
        LineNode* curr = head;
        for (int i = 0; i < index; i++) curr = curr->next;
        return &(curr->text);
    }
};

// ============================================================================
// TEXT EDITOR CONTROLLER
// ============================================================================
class TextEditor {
private:
    TextBuffer buffer;
    string currentFile;
    string recentFiles[5];
    int recentCount;

    string textColor;
    string textFont;
    int textSize;
    bool wordWrap;

    int currentPage;
    const int LINES_PER_PAGE = 5;

    vector<string> fontList = {"Arial", "Times New Roman", "Courier New", "Verdana", "Calibri"};
    vector<int> sizeList = {8, 10, 12, 14, 16, 18, 20, 24, 28, 32};

    void addToRecent(string filename) {
        for (int i = 0; i < recentCount; i++) {
            if (recentFiles[i] == filename) return;
        }
        for (int i = 4; i > 0; i--) {
            recentFiles[i] = recentFiles[i - 1];
        }
        recentFiles[0] = filename;
        if (recentCount < 5) recentCount++;
    }

    string applyWordWrap(const string& text, int width = 60) {
        if (!wordWrap || (int)text.size() <= width) return text;
        string result = "";
        int pos = 0;
        while (pos < (int)text.size()) {
            result += text.substr(pos, width);
            pos += width;
            if (pos < (int)text.size()) result += "\n      ";
        }
        return result;
    }

public:
    TextEditor() : currentFile(""), recentCount(0), textColor("Default Black"),
                   textFont("Arial"), textSize(12), wordWrap(false), currentPage(0) {}

    // --- PART A: FILE SYSTEM INTERFACES ---
    void newFile() {
        buffer.clear();
        currentFile = "Untitled.txt";
        currentPage = 0;
        cout << "Success: Created a new empty document.\n";
    }

    void openFile(string filename) {
        ifstream file(filename);
        if (!file) {
            cout << " Error: File could not be opened or found.\n";
            return;
        }
        buffer.clear();
        string line;
        while (getline(file, line)) {
            buffer.appendLine(line);
        }
        file.close();
        currentFile = filename;
        addToRecent(filename);
        currentPage = 0;
        cout << "Success: File \"" << filename << "\" loaded into Linked List memory.\n";
    }

    void saveFile() {
        if (currentFile.empty() || currentFile == "Untitled.txt") {
            cout << "Enter target filename to save: ";
            cin >> currentFile;
        }
        ofstream file(currentFile);
        LineNode* curr = buffer.getHead();
        while (curr != nullptr) {
            file << curr->text << "\n";
            curr = curr->next;
        }
        file.close();
        addToRecent(currentFile);
        cout << " Success: Document saved securely to: " << currentFile << "\n";
    }

    void saveAs(string newName) {
        currentFile = newName;
        saveFile();
    }

    void closeFile() {
        cout << " Closing file buffer: " << (currentFile.empty() ? "None" : currentFile) << "\n";
        buffer.clear();
        currentFile = "";
        currentPage = 0;
    }

    void viewRecentFiles() {
        cout << "\n=== RECENTLY ACCESSED FILES ===\n";
        if (recentCount == 0) {
            cout << "  (No recent files logged)\n";
        } else {
            for (int i = 0; i < recentCount; i++) {
                cout << "  [" << (i + 1) << "] " << recentFiles[i] << "\n";
            }
        }
    }

    // --- PART B: TEXT INTERACTIVE EDITING SYSTEMS ---
    void startInteractiveTyping() {
        if (currentFile.empty()) {
            currentFile = "Untitled.txt";
        }
        cout << "\n=== CONTINUOUS TYPING MODE ACTIVE ===\n";
        cout << "* Every time you press [Enter], a new paragraph node is created.\n";
        cout << "* To STOP typing and return to the main menu, type 'END' on a fresh blank line.\n";
        cout << "--------------------------------------------------\n";
        
        string inputLine;
        while (true) {
            getline(cin, inputLine);
            if (inputLine == "END") {
                break;
            }
            buffer.appendLine(inputLine);
        }
        cout << "Continuous stream typing exited. Changes saved to working memory.\n";
    }

    void insertTextInline(int lineIdx, int stringPos, string content) {
        string* lineStr = buffer.getLineString(lineIdx);
        if (!lineStr) {
            cout << " Error: Target line index does not exist.\n";
            return;
        }
        if (stringPos < 0 || stringPos > (int)lineStr->size()) {
            stringPos = lineStr->size(); 
        }
        lineStr->insert(stringPos, content);
        cout << " Characters injected into paragraph successfully.\n";
    }

    void deleteTextInline(int lineIdx, int stringPos, int length) {
        string* lineStr = buffer.getLineString(lineIdx);
        if (!lineStr) {
            cout << " Error: Target line index does not exist.\n";
            return;
        }
        if (stringPos < 0 || stringPos >= (int)lineStr->size()) {
            cout << " Error: Character position column out of bounds.\n";
            return;
        }
        lineStr->erase(stringPos, length);
        cout << " Substring data successfully erased from line.\n";
    }

    void insertNewParagraph(int lineIdx, string content) {
        if (buffer.insertNewLineNode(lineIdx, content)) {
            cout << " Success: Inserted a complete new paragraph block at row " << (lineIdx + 1) << ".\n";
        } else {
            cout << " Error: Invalid paragraph insertion row bounds.\n";
        }
    }

    void deleteWholeParagraph(int lineIdx) {
        if (buffer.deleteLineNode(lineIdx)) {
            cout << "Success: Completely deleted paragraph block " << (lineIdx + 1) << ".\n";
        } else {
            cout << " Error: Cannot find target paragraph row index to delete.\n";
        }
    }

    void findAndReplace(string searchTarget, string replacePayload) {
        int counts = 0;
        LineNode* curr = buffer.getHead();
        while (curr != nullptr) {
            size_t foundPos = 0;
            while ((foundPos = curr->text.find(searchTarget, foundPos)) != string::npos) {
                curr->text.replace(foundPos, searchTarget.size(), replacePayload);
                foundPos += replacePayload.size();
                counts++;
            }
            curr = curr->next;
        }
        cout << " Find/Replace complete. Swapped " << counts << " instances.\n";
    }

    void changeColor(int selection) {
        switch(selection) {
            case 1: textColor = "Red"; break;
            case 2: textColor = "Blue"; break;
            case 3: textColor = "Green"; break;
            default: textColor = "Default Black";
        }
        cout << " Text layout updated color context to: " << textColor << "\n";
    }

    void displayFonts() {
        cout << "Available choices: [1] Arial | [2] Times New Roman | [3] Courier New | [4] Verdana\n";
    }

    void changeFont(int selection) {
        if (selection >= 1 && selection <= (int)fontList.size()) {
            textFont = fontList[selection - 1];
            cout << ">> Font configuration updated to: " << textFont << "\n";
        } else {
            cout << "Out of selection limits, defaults maintained.\n";
        }
    }

    void displaySizes() {
        cout << "Available choices: [1] 10pt | [2] 12pt | [3] 14pt | [4] 16pt | [5] 20pt\n";
    }

    void changeSize(int selection) {
        if (selection >= 1 && selection <= (int)sizeList.size()) {
            textSize = sizeList[selection - 1];
            cout << " Text font scaling size set to: " << textSize << "pt\n";
        }
    }

    void toggleWordWrap() {
        wordWrap = !wordWrap;
        cout << " Word-wrap rules updated -> Global state: " << (wordWrap ? "ON" : "OFF") << "\n";
    }

    void keyPageUp() {
        if (currentPage > 0) {
            currentPage--;
            cout << " Paged Up. Active Viewport Page: " << (currentPage + 1) << "\n";
        } else {
            cout << "Boundary reached: Already showing top of the file.\n";
        }
    }

    void keyPageDown() {
        int totalPages = (buffer.getLineCount() + LINES_PER_PAGE - 1) / LINES_PER_PAGE;
        if (totalPages == 0) 
            totalPages = 1;
        if (currentPage < totalPages - 1) {
            currentPage++;
            cout << " Paged Down. Active Viewport Page: " << (currentPage + 1) << "\n";
        } else {
            cout << " Boundary reached: Already viewing final page frames.\n";
        }
    }

    void keyHome() {
        currentPage = 0;
        cout << " Viewport pointer snapped directly to Page 1.\n";
    }

    void keyEnd() {
        int totalPages = (buffer.getLineCount() + LINES_PER_PAGE - 1) / LINES_PER_PAGE;
        currentPage = max(0, totalPages - 1);
        cout << " Viewport jumped immediately to the absolute last page.\n";
    }

    void selectAll() {
        cout << "\n=== [SELECT ALL ACTION] SYSTEM DATA BUFFER STREAM DUMP ===\n";
        LineNode* curr = buffer.getHead();
        int counter = 1;
        while(curr != nullptr) {
            cout << "  [Paragraph Node " << counter++ << "]: " << curr->text << "\n";
            curr = curr->next;
        }
        cout << "========================================================\n";
    }

    // Interactive UI Renderer Frame
    void renderUI() {
        cout << "\n========================================================================\n";
        cout << "\n FILE SCREEN AREA UI | OPEN DATA STRUCTURE OBJECT: " << (currentFile.empty() ? "(None Open)" : currentFile) << "\n";
        cout << "  Active Layout Metas: Font=" << textFont << " | Size=" << textSize << "pt | Color=" << textColor << "\n";
        cout << "  Word Wrapping Constraints Evaluation Directives: " << (wordWrap ? "TRUE" : "FALSE") << "\n";
        cout << "------------------------------------------------------------------------\n";

        if (buffer.getLineCount() == 0) {
            cout << "   [ Blank Document Canvas Workspace - Linked List has 0 nodes ]\n";
        } else {
            int startIdx = currentPage * LINES_PER_PAGE;
            LineNode* curr = buffer.getHead();
            
            for (int i = 0; i < startIdx && curr != nullptr; i++) {
                curr = curr->next;
            }

            for (int i = 0; i < LINES_PER_PAGE && curr != nullptr; i++) {
                cout << "  [P" << (startIdx + i + 1) << "] | " << applyWordWrap(curr->text) << "\n";
                curr = curr->next;
            }
            
            int totalPages = (buffer.getLineCount() + LINES_PER_PAGE - 1) / LINES_PER_PAGE;
            if (totalPages == 0) totalPages = 1;
            cout << "\n  --- [ Scroll-Bar Visual Track ] ---------- [ Page: " << (currentPage + 1) << " of " << totalPages << " ] ---\n";
        }
        cout << "========================================================================\n";
    }
};

