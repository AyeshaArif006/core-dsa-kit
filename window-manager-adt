#include <iostream>
#include <string>
#include <SFML/Graphics.hpp>

using namespace std;
struct Window {
    string title;
    sf::Color color;

    int width;
    int height;
    float posX;
    float posY;
    Window* prev;
    Window* next;

    Window(string t,
           sf::Color c,
           int w = 300,
           int h = 200,
           float x = 100,
           float y = 100)
    {
        title = t;
        color = c;
        width = w;
        height = h;
        posX = x;
        posY = y;
        prev = nullptr;
        next = nullptr;
    }
};

class WindowManager {
private:
    Window* head;
    int count;

public:
    WindowManager() {
        head = nullptr;
        count = 0;
    }
    void createWindow(string title,
                      sf::Color color,
                      int w = 300,
                      int h = 200,
                      float x = 100,
                      float y = 100)
    {
        Window* newWin = new Window(title, color, w, h, x, y);
        if (!head) {
            head = newWin;
        }
        else {
            Window* temp = head;

            while (temp->next) {
                temp = temp->next;
            }

            temp->next = newWin;
            newWin->prev = temp;
        }
        count++;
        cout << "[CREATE] Window '" << title << "' created.\n";
    }
    void activateWindow(Window* target) {
        if (!head || !target || head == target)
            return;
        if (target->prev)
            target->prev->next = target->next;

        if (target->next)
            target->next->prev = target->prev;
        target->prev = nullptr;
        target->next = head;
        head->prev = target;
        head = target;

        cout << "[ACTIVATE] '" << target->title
             << "' is now active.\n";
    }
    void activateByTitle(string title) {
        Window* temp = head;
        while (temp) {
            if (temp->title == title) {
                activateWindow(temp);
                return;
            }
            temp = temp->next;
        }
        cout << "[ERROR] Window not found.\n";
    }
    void resizeWindow(string title, int newW, int newH) {
        Window* temp = head;
        while (temp) {
            if (temp->title == title) {
                temp->width = newW;
                temp->height = newH;

                cout << "[RESIZE] '" << title
                     << "' resized to "
                     << newW << "x" << newH << endl;
                return;
            }
            temp = temp->next;
        }
        cout << "[ERROR] Window not found.\n";
    }
    void deleteWindow(string title) {
        if (!head) {
            cout << "[ERROR] No windows exist.\n";
            return;
        }
        Window* temp = head;
        while (temp) {
            if (temp->title == title) {
                if (temp == head) {

                    head = temp->next;

                    if (head)
                        head->prev = nullptr;
                }
                else {

                    if (temp->prev)
                        temp->prev->next = temp->next;

                    if (temp->next)
                        temp->next->prev = temp->prev;
                }
                delete temp;
                count--;
                cout << "[DELETE] '" << title
                     << "' deleted.\n";

                return;
            }
            temp = temp->next;
        }
        cout << "[ERROR] Window not found.\n";
    }
    void handleMouseClick(float mouseX, float mouseY) {
        Window* temp = head;
        while (temp) {
            if (mouseX >= temp->posX &&
                mouseX <= temp->posX + temp->width &&
                mouseY >= temp->posY &&
                mouseY <= temp->posY + temp->height)
            {
                activateWindow(temp);
                return;
            }
            temp = temp->next;
        }
    }
    void drawWindows(sf::RenderWindow& window,
                     sf::Font& font)
    {
        if (!head)
            return;

        Window* temp = head;
        while (temp->next) {
            temp = temp->next;
        }
        while (temp) {
            sf::RectangleShape rect(
                sf::Vector2f(temp->width,
                             temp->height));

            rect.setPosition(temp->posX,
                             temp->posY);

            rect.setFillColor(temp->color);

            if (temp == head) {
                rect.setOutlineThickness(5);
                rect.setOutlineColor(sf::Color::White);
            }
            else {
                rect.setOutlineThickness(2);
                rect.setOutlineColor(
                    sf::Color(60, 60, 60));
            }
            window.draw(rect);
            sf::RectangleShape titleBar(
                sf::Vector2f(temp->width, 30));

            titleBar.setPosition(temp->posX,
                                 temp->posY);

            titleBar.setFillColor(
                sf::Color(40, 40, 40));

            window.draw(titleBar);

            sf::Text text;

            text.setFont(font);
            text.setString(temp->title);
            text.setCharacterSize(16);
            text.setFillColor(sf::Color::White);
            text.setPosition(
                temp->posX + 10,
                temp->posY + 5);
            window.draw(text);
            temp = temp->prev;
        }
    }
    void displayWindows() {
        cout << "\n===== WINDOW LIST =====\n";
        if (!head) {
            cout << "No windows open.\n";
            return;
        }
        Window* temp = head;
        int i = 1;
        while (temp) {
            cout << i << ". "
                 << temp->title;

            if (temp == head)
                cout << " [ACTIVE]";
            cout << endl;
            temp = temp->next;
            i++;
        }
        cout << "=======================\n";
    }
    ~WindowManager() {
        Window* temp = head;
        while (temp) {
            Window* nxt = temp->next;
            delete temp;
            temp = nxt;
        }
    }
};
int main() {
    sf::RenderWindow window(
        sf::VideoMode(1200, 800),
        "Window Manager ADT - GUI");

    window.setFramerateLimit(60);
    sf::Font font;

    if (!font.loadFromFile(
            "C:\\Windows\\Fonts\\arial.ttf"))
    {
        cout << "Font failed to load.\n";
    }
    WindowManager wm;
    wm.createWindow(
        "File Explorer",
        sf::Color(33, 150, 243),
        350, 250,
        100, 120);

    wm.createWindow(
        "Notepad",
        sf::Color(240, 240, 240),
        400, 300,
        250, 80);

    wm.createWindow(
        "Browser",
        sf::Color(255, 152, 0),
        500, 350,
        400, 250);

    wm.createWindow(
        "Terminal",
        sf::Color(30, 30, 30),
        450, 280,
        650, 150);

    wm.displayWindows();
    wm.resizeWindow("Browser", 600, 400);
    while (window.isOpen()) {
        sf::Event event;
        while (window.pollEvent(event)) {
            if (event.type == sf::Event::Closed) {
                window.close();
            }
            if (event.type ==
                sf::Event::MouseButtonPressed)
            {
                if (event.mouseButton.button ==
                    sf::Mouse::Left)
                {
                    wm.handleMouseClick(
                        event.mouseButton.x,
                        event.mouseButton.y);
                }
            }
            if (event.type == sf::Event::KeyPressed) {
                if (event.key.code == sf::Keyboard::Delete) {
                    wm.deleteWindow("Terminal");
                }

                if (event.key.code == sf::Keyboard::Num1) {
                    wm.activateByTitle("Notepad");
                }

                if (event.key.code == sf::Keyboard::Num2) {
                    wm.activateByTitle("Browser");
                }
            }
        }
        window.clear(
            sf::Color(120, 120, 120));

        wm.drawWindows(window, font);
        window.display();
    }

    return 0;
}
