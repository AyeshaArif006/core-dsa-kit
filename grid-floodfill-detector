            "bwwbbwwb",
            "bwbwbbww",
            "bwbwwwbb",
            "bwbwwwbb",
            "bwbbbwwb",
            "bwbbbwwb"
        };
        solveGrid(figB, "Example 2: Custom 8x8 Grid");
